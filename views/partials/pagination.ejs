<div class="pagination">

  <!-- Previous -->
  <% if (currentPage > 1) { %>
    <a href="?<%= new URLSearchParams({ ...query, page: currentPage - 1 }).toString() %>">
      ← Previous
    </a>
  <% } else { %>
    <span style="color: gray;">← Previous</span>
  <% } %>


  <!-- Page numbers -->
  <% for (let i = 1; i <= totalPages; i++) { %>
    <a 
      href="?<%= new URLSearchParams({ ...query, page: i }).toString() %>"
      style="<%= currentPage === i ? 'font-weight: bold;' : '' %>"
    >
      <%= i %>
    </a>
  <% } %>


  <!-- Next -->
  <% if (currentPage < totalPages) { %>
    <a href="?<%= new URLSearchParams({ ...query, page: currentPage + 1 }).toString() %>">
      Next →
    </a>
  <% } else { %>
    <span style="color: gray;">Next →</span>
  <% } %>

</div>