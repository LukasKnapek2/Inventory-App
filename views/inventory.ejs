<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include("partials/header") %>
  <div class="filter-container">
    <h1 class="heading-over-filter">Your Inventory</h1>
    <%- include("partials/filter", { query, pageType: "inventory" }) %>
  </div>


<div class="skins">
  <% skins.forEach(skin => { %>
    <div class="skin-card">
      <img src="<%= skin.image_url %>" />
      <h3><%= skin.name %></h3>
      <p class="rarity-<%= skin.rarity %>"><%= skin.rarity %></p>
      <p>Qty: <%= skin.quantity %></p>
      <p><button class="gift-button" data-skin-id="<%= skin.id %>">Gift Skin</button></p>
    </div>
  <% }) %>
</div>

<div id="gift-modal" class="hidden">
  <form id="gift-form">
    <h2>Gift Skin</h2>
    <input type="hidden" name="skin_id" id="gift-skin-id" />
    <label for="recipient">Recipient Username:</label>
    <input type="text" name="recipient" id="recipient" placeholder="Enter username" required />
    <label for="quantity">Quantity:</label>
    <input type="number" name="quantity" id="quantity" value="1" min="1" required />
    <button id="confirm-gift" type="submit">Send Gift</button>
    <button type="button" id="cancel-gift">Cancel</button>
  </form>
</div>
<script>
  document.querySelectorAll('.gift-button').forEach(button => {
    button.addEventListener('click', () => {
      const skinId = button.getAttribute('data-skin-id');
      document.getElementById('gift-skin-id').value = skinId;
      document.getElementById('gift-modal').classList.remove('hidden');
    });
  });

  document.getElementById('cancel-gift').addEventListener('click', () => {
    document.getElementById('gift-modal').classList.add('hidden');
  });

  document.getElementById('gift-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const recipientName = document.getElementById('recipient').value;

    const response = await fetch('/inventory/gift', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        skinId: document.getElementById('gift-skin-id').value,
        recipient: recipientName,
        quantity: document.getElementById('quantity').value
      })
    });

    if (response.ok) {
      alert("Gift successful!");
      location.reload();
    } else {
      const error = await response.text();
      alert(error);
    }
  });
  </script>

<%- include("partials/pagination", { currentPage, totalPages, query }) %>

</body>
</html>